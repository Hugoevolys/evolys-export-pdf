# === Backend ===
ANTHROPIC_API_KEY=sk-ant-...
# Modele recommande : un modele avec recherche web (Sonnet recent)
ANTHROPIC_MODEL=claude-sonnet-4-6
# Port du backend en LOCAL (le proxy Vite suit ce PORT). 3002 par defaut pour
# cohabiter avec un autre projet occupant 3001. En prod, l'hote (Render) impose le port.
PORT=3002
CORS_ORIGIN=*

# === Frontend (build) ===
# URL publique du backend en prod :
# VITE_API_URL=https://chasseur-immo-estimation-api.onrender.com

# Recherche web (outil Anthropic) : on/off + nb de recherches (cout)
WEB_SEARCH=on
WEB_SEARCH_MAX_USES=6
